{
  "name": "ub-delete-then-device-edit",
  "description": "The resurrection ceiling: server delete vs a NEWER device edit. UB (0000000000000000000000SRVR) deletes at wall 2000, but the device then edits the notebook at wall 3000 (deleted_at null). LWW gives the row to the newest writer, so the notebook comes back LIVE — a UB delete only reliably beats ops older than it. This is the deliberate v1 conflict semantic (last-writer-wins), not a bug.",
  "ops": [
    {
      "table": "notebook",
      "pk": "00000000000000000000000NB1",
      "site_id": "0000000000000000000000000A",
      "op_seq": 1,
      "wall_ts": 1000,
      "cols": {
        "name": "Journal",
        "sort_order": 0,
        "created_at": 1000,
        "deleted_at": null,
        "folder_id": null
      }
    },
    {
      "table": "notebook",
      "pk": "00000000000000000000000NB1",
      "site_id": "0000000000000000000000SRVR",
      "op_seq": 1,
      "wall_ts": 2000,
      "cols": {
        "name": "Journal",
        "sort_order": 0,
        "created_at": 1000,
        "deleted_at": 2000,
        "folder_id": null
      }
    },
    {
      "table": "notebook",
      "pk": "00000000000000000000000NB1",
      "site_id": "0000000000000000000000000A",
      "op_seq": 2,
      "wall_ts": 3000,
      "cols": {
        "name": "Journal (still here)",
        "sort_order": 0,
        "created_at": 1000,
        "deleted_at": null,
        "folder_id": null
      }
    }
  ],
  "expected_state": {
    "notebook": [
      {
        "pk": "00000000000000000000000NB1",
        "site_id": "0000000000000000000000000A",
        "op_seq": 2,
        "wall_ts": 3000,
        "cols": {
          "name": "Journal (still here)",
          "sort_order": 0,
          "created_at": 1000,
          "deleted_at": null,
          "folder_id": null
        }
      }
    ],
    "page": [],
    "stroke": []
  }
}
