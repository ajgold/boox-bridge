# /etc/boox-bridge/bridge.env — copy to a real file with mode 0600 owned by root,
# then point the systemd unit's EnvironmentFile at it.

# LLM gateway (cf-llm-gateway Worker at llm.jacomail.com)
LLM_GATEWAY_URL=https://llm.jacomail.com/anthropic
LLM_GATEWAY_TOKEN=<contents of ~/.tokens/worker-master-key on dev box>

# HWR model selection. Default Sonnet 4.6 with escalation to Opus 4.7 on
# low-confidence pages. Adjust if Step 0.6 baseline finds Sonnet inadequate
# for Claire's handwriting — flip default to claude-opus-4-7 and bump
# MAX_DAILY_LLM_USD to absorb the cost (~5x Sonnet).
HWR_MODEL_DEFAULT=claude-sonnet-4-6
HWR_MODEL_ESCALATE=claude-opus-4-7

# Affine MCP (already running alongside the Affine VM)
AFFINE_MCP_URL=http://10.0.1.21:3030/mcp
AFFINE_MCP_TOKEN=<from /opt/notes-app/.env on notes VM 140>
AFFINE_WORKSPACE_ID=dc730ebd-42e8-4f0d-b3db-faf7b10f8c5a
AFFINE_PARENT_DOC_ID=S5GQRh5nis

# Pipeline behaviour
BOOX_DATA_DIR=/var/lib/boox
OWNER_LABEL=claire
DEBOUNCE_SECONDS=10
MAX_PAGES_PER_NOTE=25
MAX_DAILY_LLM_USD=2.00
